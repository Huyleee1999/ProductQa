<?xml version="1.0"?>
<schema
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table
        name="training_productqa_question"
        resource="default"
        engine="innodb"
        comment="Product QA questions">

        <column
            xsi:type="int"
            name="question_id"
            identity="true"
            nullable="false"/>

        <column
            xsi:type="int"
            name="product_id"
            nullable="false"/>

        <column
            xsi:type="int"
            name="customer_id"
            nullable="true"/>

        <column xsi:type="text"
            name="question_text"
            nullable="false"/>

        <column
            xsi:type="text"
            name="answer_text"
            nullable="true"/>

        <column
            xsi:type="varchar"
            name="status"
            length="32"
            nullable="false"
            default="pending"/>

        <column
            xsi:type="timestamp"
            name="created_at"
            nullable="false"
            default="CURRENT_TIMESTAMP"/>

        <column
            xsi:type="timestamp"
            name="updated_at"
            nullable="true"
            on_update="true"/>

        <constraint
            xsi:type="primary"
            referenceId="PRIMARY">
            <column name="question_id"/>
        </constraint>

    </table>
</schema>
